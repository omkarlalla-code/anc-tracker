[Unit]
Description=ANC Tracker Telegram Bot
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/anc-tracker
EnvironmentFile=/home/ubuntu/anc-tracker/.env
ExecStart=/usr/bin/python3 telegram_bot.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
